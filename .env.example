# Copy to .env.local and fill in values (see core-instructions.md §10)

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/cliffsense?retryWrites=true&w=majority

# Plaid (sandbox: https://dashboard.plaid.com/developers/sandbox)
PLAID_CLIENT_ID=69de521320b4db000dc20e65
PLAID_SECRET=26606bf06fafa29d74874a8ffe978a
# sandbox | production
PLAID_ENV=sandbox
# openssl rand -base64 32  →  must decode to 32 bytes. NEVER rotate without re-linking every bank.
PLAID_ENCRYPTION_KEY=
# Plaid webhook URL — must be HTTPS and publicly reachable. Falls back to NEXTAUTH_URL+/api/plaid/webhook
# PLAID_WEBHOOK_URL=https://your-domain.com/api/plaid/webhook
# Plaid OAuth redirect URI — required for OAuth banks (Chase, BofA, Wells Fargo, Cap One, etc.) in production.
# Must be registered in the Plaid dashboard under "Allowed redirect URIs".
# PLAID_REDIRECT_URI=https://your-domain.com/onboarding/plaid

# Mailgun (https://mailgun.com) — handles ALL email: verification, login codes,
# password reset, alerts, and digests. Sandbox domains only deliver to authorized
# recipients; production should use a verified domain (e.g. mybenefitspa.com).
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=sandbox....mailgun.org   (prod: mybenefitspa.com)
# US region default; EU accounts use https://api.eu.mailgun.net
# MAILGUN_BASE_URL=https://api.mailgun.net
# Verified sender, e.g. MyBenefitsPA <alerts@mybenefitspa.com>
# MAILGUN_FROM_EMAIL=

# Public base URL for links in emails (verification, invites, digests, resets).
# Falls back to NEXTAUTH_URL.
# APP_URL=https://mybenefitspa.com

# Scheduled jobs: /api/cron/sync (daily Plaid sync + threshold alerts) and
# /api/cron/digest?frequency=daily|weekly (summary emails).
# On Vercel, Vercel Cron (vercel.json) is authorized automatically. On Railway,
# Render, Fly, etc. there is NO automatic auth — you MUST set CRON_SECRET and
# drive the endpoints from an external scheduler (the bundled GitHub Actions
# workflow at .github/workflows/cron.yml, or cron-job.org) sending
# `Authorization: Bearer $CRON_SECRET`. Without CRON_SECRET these routes fail
# closed (no scheduled syncs, alerts, or digests). openssl rand -base64 32
# CRON_SECRET=

# Web Push (VAPID) — installed-PWA push notifications for alerts.
# Generate a keypair: node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is safe to expose; keep the private key secret.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:alerts@mybenefitspa.com

# Anthropic — required to enable the AI advisor (/advisor). Without it the
# advisor returns a "not configured" notice; the rest of the app runs fine.
# ANTHROPIC_API_KEY=
# Optional advisor tuning (defaults shown):
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=1024

# App health: GET /api/health returns { ok, mongo, timestamp } (no auth; middleware allows this path).
