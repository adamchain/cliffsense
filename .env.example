# Copy to .env.local and fill in values (see core-instructions.md §10)

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/cliffsense?retryWrites=true&w=majority

# Plaid (sandbox: https://dashboard.plaid.com/developers/sandbox)
PLAID_CLIENT_ID=69de521320b4db000dc20e65
PLAID_SECRET=26606bf06fafa29d74874a8ffe978a
# sandbox | production
PLAID_ENV=sandbox
# openssl rand -base64 32  →  must decode to 32 bytes. NEVER rotate without re-linking every bank.
PLAID_ENCRYPTION_KEY=
# Plaid webhook URL — must be HTTPS and publicly reachable. Falls back to NEXTAUTH_URL+/api/plaid/webhook
# PLAID_WEBHOOK_URL=https://your-domain.com/api/plaid/webhook
# Plaid OAuth redirect URI — required for OAuth banks (Chase, BofA, Wells Fargo, Cap One, etc.) in production.
# Must be registered in the Plaid dashboard under "Allowed redirect URIs".
# PLAID_REDIRECT_URI=https://your-domain.com/onboarding/plaid

# Resend (https://resend.com) — alert emails after sync / threshold evaluation
# RESEND_API_KEY=
# Verified sender, e.g. CliffSense <alerts@yourdomain.com> (Resend dashboard)
# RESEND_FROM_EMAIL=

# Public base URL for links in emails (verification, invites, digests, resets).
# Falls back to NEXTAUTH_URL.
# APP_URL=http://localhost:3000

# Scheduled jobs (see vercel.json crons: /api/cron/sync, /api/cron/digest).
# Vercel Cron is authorized automatically; for manual/self-hosted triggers send
# `Authorization: Bearer $CRON_SECRET`. openssl rand -base64 32
# CRON_SECRET=

# Optional: Anthropic for advisor
# ANTHROPIC_API_KEY=

# App health: GET /api/health returns { ok, mongo, timestamp } (no auth; middleware allows this path).
